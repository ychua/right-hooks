{
  "name": "strict",
  "description": "Full lifecycle \u2014 planning, implementation, review, QA, learnings",
  "triggers": {
    "branchPrefix": [
      "feat/"
    ]
  },
  "gates": {
    "ci": true,
    "dod": true,
    "docConsistency": true,
    "planningArtifacts": true,
    "engReview": true,
    "codeReview": true,
    "qa": true,
    "learnings": true,
    "stopHook": true,
    "postEditCheck": true
  }
}
