{
  "name": "light",
  "description": "CI only \u2014 minimal enforcement for docs and chores",
  "triggers": {
    "branchPrefix": [
      "docs/",
      "chore/",
      "hotfix/"
    ]
  },
  "gates": {
    "ci": true,
    "dod": true,
    "docConsistency": true,
    "planningArtifacts": false,
    "engReview": false,
    "codeReview": false,
    "qa": false,
    "learnings": false,
    "stopHook": false,
    "postEditCheck": true
  }
}
